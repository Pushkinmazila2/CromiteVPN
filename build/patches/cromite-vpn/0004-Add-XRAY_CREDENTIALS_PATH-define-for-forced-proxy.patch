From 54b37370b13b5419197a6a1a854476712bc24c96 Mon Sep 17 00:00:00 2001
From: Your Name <you@example.com>
Date: Sun, 12 Apr 2026 15:48:05 +0000
Subject: [PATCH] Add XRAY_CREDENTIALS_PATH define for forced proxy

---
 chrome/browser/BUILD.gn | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/chrome/browser/BUILD.gn b/chrome/browser/BUILD.gn
index edf0410de1..cd19a78955 100644
--- a/chrome/browser/BUILD.gn
+++ b/chrome/browser/BUILD.gn
@@ -1563,6 +1563,8 @@ static_library("browser") {
     "//build/config:precompiled_headers",
   ]
   defines = [ "ZLIB_CONST" ]
+  # CromiteVPN: path to xray credentials file written by Kotlin on startup
+  defines += [ "XRAY_CREDENTIALS_PATH=\"/data/data/com.cromitevpn.browser/files/xray.creds\"" ]

   if (is_chrome_branded || use_official_enterprise_connectors_api_keys) {
     defines += [ "USE_OFFICIAL_ENTERPRISE_CONNECTORS_API_KEYS=1" ]
--
2.25.1